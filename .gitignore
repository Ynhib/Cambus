# =========================================
# MOBILE (Capacitor)
# =========================================
# Note : Capacitor recommande de commit les dossiers /android et /ios 
# mais on ignore les builds lourds générés à l'intérieur
/android/app/build/
/android/.gradle/
/android/local.properties
/ios/App/Pods/
/ios/App/build/
/ios/App/App.xcworkspace/xcuserdata/

# =========================================
# TESTS ET CACHE
# =========================================
/coverage
.eslintcache
.stylelintcache